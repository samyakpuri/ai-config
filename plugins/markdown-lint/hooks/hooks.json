{
  "description": "Runs markdownlint after writing or editing .md files and surfaces violations as suggestions",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NonInteractive -File \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/lint-md.ps1\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
